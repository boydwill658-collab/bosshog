{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "driver", "admin"] },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Merchant": {
      "title": "Merchant",
      "description": "Restaurants or stores",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "deliveryTime": { "type": "string" },
        "image": { "type": "string" },
        "menu": { "type": "array" },
        "ratings": {
          "type": "array",
          "description": "List of user ratings: { userId: string, score: number, comment: string }"
        }
      },
      "required": ["name", "category"]
    },
    "Order": {
      "title": "Delivery Order",
      "description": "Orders placed by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "driverId": { "type": "string" },
        "merchantId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "preparing", "out-for-delivery", "delivered", "cancelled"] },
        "currentLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "merchantId", "items", "total", "status"]
    },
    "DriverApplication": {
      "title": "Driver Application",
      "description": "Applications for new drivers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "isVeteran": { "type": "boolean" },
        "vehicleType": { "type": "string", "enum": ["car", "truck", "motorcycle", "bicycle"] },
        "vehicleDetails": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "phoneNumber", "vehicleType"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Messages sent in an order chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "BusinessPledge": {
      "title": "Business Pledge",
      "description": "Community impact pledges from local businesses",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "pledgeType": { "type": "string", "enum": ["money", "materials", "labor"] },
        "details": { "type": "string" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["businessName", "pledgeType", "details", "verified", "createdAt"]
    },
    "BandGiveaway": {
      "title": "Band Giveaway Entry",
      "description": "Entries for the band trailer giveaway",
      "type": "object",
      "properties": {
        "bandName": { "type": "string" },
        "genre": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bandName", "genre", "createdAt"]
    },
    "CommunityMoment": {
      "title": "Community Moment",
      "description": "User-shared photos of favorite places or concerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "image": { "type": "string", "description": "Base64 or URL of the photo" },
        "caption": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["place", "concert"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "image", "caption", "type", "createdAt"]
    },
    "NeighborNomination": {
      "title": "Neighbor Nomination",
      "description": "Nomination for a $1000 home cleanup service",
      "type": "object",
      "properties": {
        "nominatorId": { "type": "string" },
        "nominatorName": { "type": "string" },
        "nomineeName": { "type": "string" },
        "nomineeAddress": { "type": "string" },
        "reason": { "type": "string" },
        "votes": { "type": "array", "description": "List of user IDs who voted" },
        "status": { "type": "string", "enum": ["nominated", "selected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nominatorId", "nomineeName", "reason", "votes", "status", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "merchants": {
      "schema": "Merchant",
      "description": "Collection of merchants"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "drivers": {
      "schema": "DriverApplication",
      "description": "Collection of driver applications"
    },
    "chats": {
      "schema": "ChatMessage",
      "description": "Messages for an order chat: /chats/{orderId}/messages/{messageId}"
    },
    "pledges": {
      "schema": "BusinessPledge",
      "description": "Collection of business impact pledges"
    },
    "band_giveaway": {
      "schema": "BandGiveaway",
      "description": "Collection of band giveaway entries"
    },
    "moments": {
      "schema": "CommunityMoment",
      "description": "Collection of shared community moments"
    },
    "nominations": {
      "schema": "NeighborNomination",
      "description": "Collection of community service nominations"
    }
  }
}
