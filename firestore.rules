rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Rules
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['customer', 'driver', 'admin'];
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'address']);
    }

    // Merchant Rules (Public read, Admin write)
    function isValidMerchant(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.category is string;
    }

    match /merchants/{merchantId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['ratings', 'rating']) &&
        incoming().ratings.size() > existing().ratings.size()
      );
    }

    // Order Rules
    function isValidOrder(data) {
      return data.customerId is string && data.merchantId is string &&
             data.items is list && data.total is number &&
             data.status in ['pending', 'confirmed', 'preparing', 'out-for-delivery', 'delivered', 'cancelled'];
    }

    match /orders/{orderId} {
      allow get: if isOwner(existing().customerId) || (isSignedIn() && existing().driverId == request.auth.uid) || isAdmin();
      allow list: if isOwner(resource.data.customerId) || (isSignedIn() && resource.data.driverId == request.auth.uid) || isAdmin() || (
        isSignedIn() && resource.data.status in ['confirmed', 'preparing', 'out-for-delivery']
      );
      allow create: if isSignedIn() && isOwner(incoming().customerId) && isValidOrder(incoming());
      allow update: if (isOwner(existing().customerId) && incoming().status == 'cancelled' && 
                        existing().status == 'pending' && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
                    (isSignedIn() && (existing().driverId == request.auth.uid || existing().driverId == null) && 
                     incoming().diff(existing()).affectedKeys().hasAll(['status', 'driverId'])) ||
                    isAdmin();
    }

    // Community Rules
    match /pledges/{pledgeId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /band_giveaway/{entryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Nominations Rules
    function isValidNomination(data) {
      return data.nominatorId == request.auth.uid &&
             data.nomineeName is string && data.nomineeName.size() <= 100 &&
             data.reason is string && data.reason.size() <= 2000 &&
             data.votes is list &&
             data.status in ['nominated', 'selected', 'completed'] &&
             data.createdAt is string;
    }

    match /nominations/{nominationId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidNomination(incoming()) && 
                      incoming().votes.size() == 1 && 
                      incoming().votes[0] == request.auth.uid;
      allow update: if (isSignedIn() && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['votes']) &&
                        incoming().votes.size() > existing().votes.size() &&
                        request.auth.uid in incoming().votes) || 
                    isAdmin();
      allow delete: if isAdmin();
    }

    match /moments/{momentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(momentId) && 
                      incoming().userId == request.auth.uid &&
                      incoming().image.size() <= 1048576; // 1MB limit for base64
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // Driver Application Rules
    function isValidDriverApp(data) {
      return data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.phoneNumber is string && data.phoneNumber.size() <= 20 &&
             data.isVeteran is bool &&
             data.vehicleType in ['car', 'truck', 'motorcycle', 'bicycle'] &&
             data.status == 'pending';
    }

    match /drivers/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidDriverApp(incoming());
      allow update: if (isOwner(userId) && existing().status == 'pending' && isValidDriverApp(incoming())) || isAdmin();
    }

    // Admin List
    match /admins/{adminId} {
      allow read: if isAdmin();
    }

    // Chat Rules
    function isValidChatMessage(data) {
      return data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 1000;
    }

    match /chats/{orderId}/messages/{messageId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid ||
        get(/databases/$(database)/documents/orders/$(orderId)).data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid ||
        get(/databases/$(database)/documents/orders/$(orderId)).data.driverId == request.auth.uid
      ) && isValidChatMessage(incoming());
    }
  }
}
